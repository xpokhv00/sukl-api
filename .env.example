PORT=3000
NODE_ENV=development

# Prisma requires two URLs when using a connection pooler (e.g. Supabase):
# DATABASE_URL  → pooled connection (used at runtime)
# DIRECT_URL    → direct connection (used for migrations)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&connect_timeout=30"
